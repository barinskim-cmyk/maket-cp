const BASE_URL = process.env.MAKET_BASE_URL || 'http://localhost:5173';

// TODO(qa): env vars with test credentials (1Password entry).
const QA_OWNER_EMAIL = process.env.QA_OWNER_EMAIL || 'qa-owner@maket.test';
const QA_OWNER_PWD   = process.env.QA_OWNER_PWD   || '';

// Share-link fixture project: pre-seeded project with a known set of
// cards + photos so expectations are deterministic.
// TODO(qa): seed via Supabase service-role in a beforeAll, or rely on
// a persistent fixture project kept in staging db.
const FIXTURE_PROJECT_SLUG = 'qa-share-link-fixture';

// Time-to-open budget for guest: if a share-link takes longer than
// this to render photos, that is itself a bug (UX regression).
const GUEST_OPEN_BUDGET_MS = 4000;

// ───────────────────────────────────────────────────────────────
//  Setup / teardown
// ───────────────────────────────────────────────────────────────

test.beforeEach(async ({ page }) => {
