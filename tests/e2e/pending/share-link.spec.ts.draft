//  Happy path — create / open / scope
// ═══════════════════════════════════════════════════════════════

test.describe('Share-link — happy path', () => {

  test('SL-REG-01: Owner can create a share-link for a project', async ({ page }) => {
    // Pre-condition: logged in as owner, FIXTURE_PROJECT_SLUG exists.
    //
    // Steps:
    //   1. page.goto(BASE_URL + '/#project/' + FIXTURE_PROJECT_SLUG);
    //   2. page.click('[data-test="share-link-button"]');
    //   3. Wait for modal: page.waitForSelector('[data-test="share-modal"]');
    //   4. page.click('[data-test="share-create"]');
    //   5. Read URL from input[data-test="share-url"].
    //
    // Expected:
    //   - URL matches /share/[a-f0-9-]{36}/ token pattern.
    //   - `share_links` row exists with status='active'.
    //   - Token is unique per click (idempotency not required here).
    //
    // TODO(qa): implement — selectors are guesses, align with DAD markup.
    test.fixme(true, 'Not yet implemented');
  });

  test('SL-REG-02: Share-link opens for an unauthenticated guest', async ({ browser }) => {
    // Requires two contexts so the guest has no session.
    //
    // Steps:
    //   const ownerCtx = await browser.newContext({ storageState: 'qa-owner.json' });
    //   const guestCtx = await browser.newContext(); // anonymous
    //   const ownerPage = await ownerCtx.newPage();
    //   // ... create share-link via ownerPage (reuse SL-REG-01 helper) ...
    //   const shareUrl = await createShareLink(ownerPage, FIXTURE_PROJECT_SLUG);
    //   const guestPage = await guestCtx.newPage();
    //   const started = Date.now();
    //   await guestPage.goto(shareUrl);
    //   await guestPage.waitForSelector('[data-test="share-gallery"]');
    //   const elapsed = Date.now() - started;
    //
    // Expected:
    //   - No auth-gate shown.
    //   - Guest sees gallery within GUEST_OPEN_BUDGET_MS.
    //   - No console errors of level "error".
    //
    // TODO(qa): implement.
    test.fixme(true, 'Not yet implemented');
  });

  test('SL-REG-03: Guest sees exactly the photos in the share scope', async ({ browser }) => {
    // Scope here = the set of photos the owner included when creating
    // the link. Assumes the link was created with scope = "all approved
    // cards in project" (default scope per current product spec).
    //
    // Pre-condition: FIXTURE_PROJECT_SLUG has a deterministic set of
    //   - 12 approved photos
    //   - 5 rejected photos (must NOT leak to guest)
    //   - 3 draft photos (must NOT leak)
    //
    // Steps:
    //   1. Owner creates share-link with default scope.
    //   2. Guest opens URL.
    //   3. Count [data-test="share-photo-tile"] elements.
    //   4. Read data-photo-id attribute on each tile.
    //
    // Expected:
    //   - Exactly 12 tiles rendered.
    //   - Set of photo IDs === set of approved photos from fixture.
    //   - No 'rejected' or 'draft' IDs leak into DOM.
    //
    // Rationale: this is the single test that guards against RLS drift.
    // If this passes, scope-leak is unlikely. If it fails, assume
    // critical severity → open bug with area='share-link'.
    //
    // TODO(qa): implement + wire to a service-role helper that returns
