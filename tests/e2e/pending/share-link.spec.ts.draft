    test.fixme(true, 'Not yet implemented');
  });

});

// ═══════════════════════════════════════════════════════════════
//  Permissions — comment allowed / disallowed
// ═══════════════════════════════════════════════════════════════

test.describe('Share-link — permissions', () => {

  test('SL-REG-04: Guest can leave a comment when comment-perm is enabled', async ({ browser }) => {
    // Pre-condition: owner creates link with permissions = { comment: true }.
    //
    // Steps:
    //   1. createShareLink(ownerPage, FIXTURE_PROJECT_SLUG, { comment: true }).
    //   2. Guest opens URL.
    //   3. Click on a photo tile → opens lightbox.
    //   4. Find comment textarea, type "QA smoke comment".
    //   5. Submit.
    //
    // Expected:
    //   - Comment appears in DOM immediately (optimistic render).
    //   - Supabase `comments` table has a new row with author=<guest-hash>.
    //   - Owner sees the comment in the cards editor without reload (if
    //     realtime is connected) or after reload (fallback).
    //
    // Edge: comment body is trimmed of leading/trailing whitespace.
    //   Empty comment must be rejected client-side (no POST).
    //
    // TODO(qa): implement.
    test.fixme(true, 'Not yet implemented');
  });

  test('SL-REG-05: Guest cannot comment when comment-perm is disabled', async ({ browser }) => {
    // Pre-condition: owner creates link with permissions = { comment: false }.
    //
    // Steps:
    //   1. createShareLink(ownerPage, FIXTURE_PROJECT_SLUG, { comment: false }).
    //   2. Guest opens URL.
    //   3. Open lightbox.
    //
    // Expected:
    //   - Comment textarea is not rendered at all (preferred) OR is
    //     rendered as read-only with tooltip "Комментарии отключены".
    //   - If guest tries to POST comment via crafted request directly
    //     to `comments` endpoint — RLS must reject with 403.
    //   - No `comments` row inserted.
    //
    // Rationale: this is as much a security test as a UX test. If
    // frontend hides the textarea but RLS allows insert, that's a
    // critical severity bug (malicious guest could spam).
    //
    // TODO(qa): implement + include raw supabase-js insert attempt.
    test.fixme(true, 'Not yet implemented');
  });

});

// ═══════════════════════════════════════════════════════════════
//  Revocation lifecycle
// ═══════════════════════════════════════════════════════════════

test.describe('Share-link — revocation', () => {

  test('SL-REG-06: Owner can revoke an active share-link', async ({ page }) => {
    // Pre-condition: owner created a share-link earlier.
    //
    // Steps:
    //   1. page.goto(BASE_URL + '/#project/' + FIXTURE_PROJECT_SLUG);
    //   2. Open share-link manager modal.
    //   3. Click [data-test="share-revoke"] on an active link.
    //   4. Confirm destructive-action dialog.
    //
    // Expected:
    //   - `share_links` row status changes from 'active' to 'revoked'.
    //   - Modal reflects the new state (strikethrough or "Отозвана" badge).
    //   - No cached token remains in localStorage.
    //
    // TODO(qa): implement.
    test.fixme(true, 'Not yet implemented');
  });

  test('SL-REG-07: A revoked share-link does not grant access', async ({ browser }) => {
    // Steps:
    //   1. Owner creates share-link.
    //   2. Guest A opens it → success (prime the cache).
    //   3. Owner revokes it.
    //   4. Guest B opens the same URL.
    //   5. Guest A refreshes their tab.
    //
    // Expected:
    //   - Guest B sees friendly error: "Ссылка больше не действует".
    //     Page title / h1 is understandable, no stack trace, no 500.
    //   - Guest A's refresh also sees friendly error (cached HTML must
    //     not survive revocation — verify via realtime or next request).
    //   - Network returns 403 or 410 (Gone); 500 is a bug.
    //
    // Edge: if the guest already has cards cached in memory and the
    // owner revokes mid-session — current product decision (TODO: confirm
    // with CoS) is that the guest is *not* force-logged-out, but any
    // new request (comment, photo load) fails with same friendly error.
    //
    // TODO(qa): implement.
    test.fixme(true, 'Not yet implemented');
  });

});

