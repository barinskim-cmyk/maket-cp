    //   const pA = await ctxA.newPage();
    //   const pB = await ctxB.newPage();
    //   // navigate both to the same project's rename screen ...
    //   await Promise.all([
    //     uploadFixture(pA, FIXTURE_SMALL),
    //     uploadFixture(pB, FIXTURE_COLLISIONS),
    //   ]);
    //   await Promise.all([applyRename(pA), applyRename(pB)]);
    //
    // Expected:
    //   - Both batches complete.
    //   - Final file set is the union of both batches (no lost uploads).
    //   - Collision rules still produce stable _N suffixes, and no two
    //     files end up with identical names.
    //   - No 500 from Supabase; no RLS false-negative.
    //
    // TODO(qa): implement. This test is expected to be flaky until
