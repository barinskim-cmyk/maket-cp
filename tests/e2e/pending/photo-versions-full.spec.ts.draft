async function enableCompareViewFlag(page: Page): Promise<void> {
  await page.evaluate(() => localStorage.setItem('DEBUG_COMPARE_VIEW', '1'));
  await page.reload();
}

async function disableCompareViewFlag(page: Page): Promise<void> {
  await page.evaluate(() => localStorage.removeItem('DEBUG_COMPARE_VIEW'));
  await page.reload();
}

